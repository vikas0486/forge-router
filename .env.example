# ──────────────────────────────────────────────────────────────────────────
# Forge Router — environment template
# ──────────────────────────────────────────────────────────────────────────
# 1. Copy this file to ".env" in the same folder:   cp .env.example .env
# 2. Fill in the keys you have (more keys = more providers available).
# 3. NEVER commit your real ".env" — it is gitignored. Each teammate uses their own.
#
# The app launches and routes WITHOUT any keys, but every provider will report
# FAILED in `forge doctor` until at least one credential below is set (or you
# run a local model via Ollama).
# ──────────────────────────────────────────────────────────────────────────

# ── Cloud LLM providers ───────────────────────────────────────────────────
# Anthropic Claude            — enables: claude, agentic/reasoning routing
ANTHROPIC_API_KEY=

# Google Gemini               — enables: gemini, summarization routing
GEMINI_API_KEY=

# Groq (LLaMA 3.3 70B)        — enables: groq, hermes; fastest chat path
GROQ_API_KEY=

# OpenAI (GPT-4o)             — enables: openai, codex
OPENAI_API_KEY=

# GitHub token                — enables: copilot / codex auth where applicable
GITHUB_TOKEN=

# Antigravity (Gemini Flash)  — optional; also needs the local `agy` CLI installed
ANTIGRAVITY_API_KEY=

# Sakana AI                   — optional
SAKANA_API_KEY=

# ── Local model (offline) — only if you run Ollama ────────────────────────
# Install from https://ollama.com, then:  ollama pull llama3 && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── App settings ──────────────────────────────────────────────────────────
DEBUG=false
TIMEOUT=30
